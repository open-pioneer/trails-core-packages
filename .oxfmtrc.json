{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "tabWidth": 4,
  "trailingComma": "none",
  "singleQuote": false,
  "quoteProps": "preserve",
  "printWidth": 100,
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist",
    "node_modules",
    "temp",
    "test-data",
    "__snapshots",
    "pnpm-lock.yaml",
    "**/chakra-snippets/**/*.tsx"
  ]
}
